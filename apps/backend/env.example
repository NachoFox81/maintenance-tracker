# Server Configuration
NODE_ENV=development
PORT=3001

# Database
# Local Mongo fallback:
MONGODB_URI=mongodb://localhost:27017/doorloop_assessment
# Atlas example:
# MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/doorloop_assessment?retryWrites=true&w=majority&appName=<app-name>

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000
